# Security baseline (DEVOPS-390 → DEVOPS-495) — non-secret, safe to commit
allow-git=none
allow-remote=none              # npm 12 default; pinned explicit for fail-closed clarity
strict-allow-scripts=true      # unreviewed dep install script = hard error
min-release-age=3
min-release-age-exclude[]=@finsys/*
min-release-age-exclude[]=@extragalaxies/*
strict-npmrc=true              # hard-error on unknown/typo'd .npmrc keys
engine-strict=true             # hard-fail on npm/Node below the engines floor
