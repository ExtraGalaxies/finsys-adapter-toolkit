{
  "name": "@finsys/adapter-toolkit",
  "version": "0.1.1",
  "description": "Partner SDK for the FinSys Source Adapter Framework — manifest validator, fixture harness, mock consumer, and reference examples for adapter authors.",
  "license": "Apache-2.0",
  "type": "module",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    }
  },
  "bin": {
    "finsys-adapter-toolkit": "dist/cli.js"
  },
  "files": [
    "dist",
    "examples",
    "README.md",
    "LICENSE"
  ],
  "scripts": {
    "build": "tsup",
    "lint": "tsc --noEmit",
    "test": "vitest run",
    "dev": "tsup --watch",
    "prepublishOnly": "npm run build",
    "docs:canonical-fields": "node scripts/gen-canonical-fields.mjs"
  },
  "engines": {
    "node": ">=24",
    "npm": ">=11.10.0"
  },
  "dependencies": {
    "@finsys/core": "^3.1.0",
    "ajv": "^8.20.0"
  },
  "devDependencies": {
    "@lavamoat/allow-scripts": "^5.0.2",
    "@types/node": "^22.0.0",
    "tsup": "^8.0.0",
    "typescript": "^5.9.0",
    "vitest": "^2.0.0"
  },
  "publishConfig": {
    "access": "public"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/ExtraGalaxies/finsys-adapter-toolkit.git"
  },
  "lavamoat": {
    "allowScripts": {
      "tsup>esbuild#0.27.7": false,
      "vitest>vite>esbuild#0.21.5": false
    }
  }
}
